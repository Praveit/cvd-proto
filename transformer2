def format_text_file(input_file, output_file):
    try:
        with open(input_file, 'r') as infile, open(output_file, 'w') as outfile:
            for line in infile:
                formatted_line = f"        [{line.strip()}],\n"
                outfile.write(formatted_line)
        print(f"File formatted successfully. Output saved to {output_file}")
    except FileNotFoundError:
        print(f"Error: The file {input_file} does not exist.")
    except Exception as e:
        print(f"An error occurred: {e}")

# Replace 'input.txt' and 'output.txt' with your file paths
input_file = 'input.txt'
output_file = 'output.txt'
format_text_file(input_file, output_file)
